# --- Reddit API ---  https://www.reddit.com/prefs/apps  (create a "script" app)
# Leave blank for now if you don't have access yet; the app will skip Reddit.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=content-goldmine/0.1 by your_reddit_username

# --- YouTube Data API v3 ---  https://console.cloud.google.com
YOUTUBE_API_KEY=

# --- LLM provider (optional but recommended) ---
# Option A: OpenRouter (has free models).  https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Optional, only to appear on OpenRouter leaderboards:
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=ContentGoldmine

# Option B: OpenAI (used only if OPENROUTER_API_KEY is empty).  https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# If BOTH OpenRouter and OpenAI keys are empty, the analyzer falls back to
# free keyword-based clustering so the app still works.
